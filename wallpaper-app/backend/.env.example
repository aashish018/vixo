SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wallpaperdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_JPA_HIBERNATE_DDL_AUTO=update

CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,DELETE,OPTIONS

APP_RATE_LIMIT_CAPACITY=100
APP_RATE_LIMIT_DURATION_MINUTES=10
APP_UPLOAD_MAX_FILE_SIZE=15MB
APP_UPLOAD_MAX_REQUEST_SIZE=15MB

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=wallpaper-app

APP_SEED_ENABLED=false
